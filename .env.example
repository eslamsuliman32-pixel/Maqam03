# ==========================================
# 1. CORE APPLICATION CONFIGURATION
# ==========================================
# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"


# ==========================================
# 2. AI ORCHESTRATION ENGINE (PRIMARY: GROQ)
# ==========================================
# Primary API Key for AI operations. 
VITE_GROQ_API_KEY="MY_GROQ_API_KEY"

# Fallback / Secondary AI Provider
VITE_CLAUDE_API_KEY="YOUR_CLAUDE_API_KEY"

# ------------------------------------------
# Deprecated AI Services (Gemini Standard Keys)
# Commented out to prevent accidental usage and enforce the multi-key pool layer.
# ------------------------------------------
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"


# ==========================================
# 3. FIREBASE INFRASTRUCTURE (AUTH & DB)
# ==========================================
# Critical backend services. Do not alter variable names
VITE_FIREBASE_API_KEY="your_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"


